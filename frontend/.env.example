# Vite dev/preview proxies these backend routes to the upstream below by default,
# so the browser sees same-origin and CORS is not needed:
#   /api  /health  /test-console  /static
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Default terminal id surfaced in the TopBar input.
VITE_DEFAULT_TERMINAL_ID=demo-kitchen-001

# Only set this if you want to bypass the Vite proxy and hit the backend directly
# (e.g. serving the built dist/ from a different origin that DOES enable CORS).
# When empty, the frontend uses relative URLs and relies on same-origin.
# VITE_API_BASE_URL=
